rules_version = '2';

// This Firestore database (project dharma-501312) is SHARED by several apps
// (ask-sanjeev, learn-from-sanjeev, gems-of-bollywood, buffer, ...). Every app
// is fully server-mediated: the browser only signs in, and all reads/writes go
// through each app's API routes using the Admin SDK (which bypasses these
// rules). So no client ever needs direct access — deny everything. This keeps
// the shared ruleset simple and decoupled: no app's data model leaks into
// another's rules.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
